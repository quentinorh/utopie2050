<% unique_id = SecureRandom.uuid %>
<div data-controller="hero"
     data-hero-unique-id-value="<%= unique_id %>"
     class="hero-stage h-[100vh] w-full relative bg-[#000000] controls-collapsed overflow-hidden">
  <div class="absolute inset-0" data-hero-target="bgLayer">
    <svg data-hero-target="svg" shape-rendering="auto" viewBox="0 0 1920 1080" preserveAspectRatio="xMidYMid meet">
      <defs>
        <radialGradient id="gradient1-<%= unique_id %>" cx="50%" cy="50%" r="50%">
          <stop offset="0%"/>
          <stop offset="100%"/>
        </radialGradient>
        <radialGradient id="gradient2-<%= unique_id %>" cx="50%" cy="50%" r="50%">
          <stop offset="0%"/>
          <stop offset="100%"/>
        </radialGradient>
        <radialGradient id="gradient3-<%= unique_id %>" cx="50%" cy="50%" r="50%">
          <stop offset="0%"/>
          <stop offset="100%"/>
        </radialGradient>
      </defs>
      <g data-hero-target="curveGroup"></g>
    </svg>
  </div>

  <div class="pointer-events-none absolute inset-0 z-[1] bg-[rgba(18,17,50,0.65)]" aria-hidden="true"></div>

  <div data-controller="hero-animation"
       class="absolute inset-0 z-[2] flex h-[100vh] flex-col items-center justify-center">
    <div class="hidden w-full" data-hero-animation-target="content">
      <div class="mb-2 flex flex-col justify-center mx-auto p-4 md:p-12 lg:w-3/4">
        <% pc = @published_posts_count %>
        <% ac = @published_authors_count %>
        <p class="mb-xs max-w-[min(100vw-2rem,32rem)] self-center text-center font-mono text-xs uppercase leading-snug tracking-wide text-white sm:text-sm md:text-base">
          <%= number_with_delimiter(pc) %>
          <%= pc == 1 ? "récit publié" : "récits publiés" %>
          par
          <%= number_with_delimiter(ac) %>
          <%= ac == 1 ? "auteur" : "auteur·ices" %>
        </p>
        <h1 class="text-center text-balance text-3xl leading-none text-white sm:text-xxl sm:leading-none lg:text-display lg:leading-none">
          <span data-hero-animation-target="title">Explorer le monde en 2050</span>
        </h1>
        <p class="max-w-[min(100vw-2rem,40rem)] self-center text-center font-sans text-base text-balance leading-snug text-white sm:text-l md:text-2l">
          Lire et écrire des futurs désirables
        </p>
        <div class="mt-sm flex flex-row flex-wrap items-center justify-center gap-2 sm:gap-sm" data-hero-animation-target="buttons">
          <%= link_to posts_path,
              class: "btn-animate-chars btn-animate-chars--primary btn-animate-chars--hero-mobile",
              data: { controller: "stagger-chars" },
              "aria-label": "Lire les futurs" do %>
            <div class="btn-animate-chars__bg"></div>
            <span data-button-animate-chars
                  data-stagger-chars-target="text"
                  class="btn-animate-chars__text">Lire les futurs</span>
          <% end %>
          <%= link_to new_post_path,
              class: "btn-animate-chars btn-animate-chars--secondary btn-animate-chars--hero-mobile",
              data: { controller: "stagger-chars" },
              "aria-label": "Écrire le futur" do %>
            <div class="btn-animate-chars__bg"></div>
            <span data-button-animate-chars
                  data-stagger-chars-target="text"
                  class="btn-animate-chars__text">Écrire le futur</span>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="pointer-events-none absolute bottom-5 z-40 flex items-center left-1/2 -translate-x-1/2 lg:bottom-10">
    <%= image_tag "CreativeCommons_logo_trademark.svg.png",
        alt: "Creative Commons",
        class: "h-7 w-auto shrink-0 brightness-0 invert sm:h-8 lg:h-9" %>
  </div>

  <div class="cover-toolbar">
    <%# .cover-pill force display:inline-flex en SCSS → !hidden pour masquer (comme .cover-controls ci-dessous). %>
    <button type="button"
            class="!hidden cover-pill cover-pill--icon cover-pill--reveal editor-randomize"
            data-action="click->hero#randomize"
            aria-label="Générer une animation aléatoire">
      <svg xmlns="http://www.w3.org/2000/svg"
           class="cover-pill__icon"
           viewBox="0 0 24 24"
           fill="none"
           stroke="currentColor"
           stroke-width="1.8"
           stroke-linecap="round"
           stroke-linejoin="round"
           aria-hidden="true">
        <rect width="12" height="12" x="2" y="10" rx="2" ry="2"/>
        <path d="m17.92 14 3.5-3.5a2.24 2.24 0 0 0 0-3l-5-4.92a2.24 2.24 0 0 0-3 0L10 6"/>
        <path d="M6 18h.01"/>
        <path d="M10 14h.01"/>
        <path d="M15 6h.01"/>
        <path d="M18 9h.01"/>
      </svg>
    </button>

    <%# .cover-controls définit display:inline-flex en SCSS → utiliser !hidden pour forcer display:none %>
    <div class="cover-controls !hidden" aria-hidden="true">
      <button type="button"
              class="cover-controls__head cover-pill cover-pill--reveal"
              data-action="click->hero#toggleControls"
              aria-expanded="false"
              aria-controls="hero-cover-controls-body-<%= unique_id %>">
        <span class="cover-controls__title">Paramètres de l'animation</span>
        <svg xmlns="http://www.w3.org/2000/svg"
             class="cover-controls__chev"
             data-hero-target="controlsToggleIcon"
             viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <polyline points="4 10 8 6 12 10"/>
        </svg>
      </button>

      <div class="cover-controls__body" id="hero-cover-controls-body-<%= unique_id %>">
        <div class="cc-stack">
          <div class="cc-row">
            <span class="cc-label">Symétrie</span>
            <div class="cc-segmented" role="radiogroup" aria-label="Symétrie">
              <button type="button"
                      class="cc-segmented__btn"
                      data-hero-target="symmetryMode"
                      data-action="click->hero#onSymmetryClick"
                      data-value="x4"
                      role="radio">×4</button>
              <button type="button"
                      class="cc-segmented__btn"
                      data-hero-target="symmetryMode"
                      data-action="click->hero#onSymmetryClick"
                      data-value="x8"
                      role="radio">×8</button>
              <button type="button"
                      class="cc-segmented__btn"
                      data-hero-target="symmetryMode"
                      data-action="click->hero#onSymmetryClick"
                      data-value="x16"
                      role="radio">×16</button>
            </div>
          </div>

          <div class="cc-row">
            <div class="cc-label-row">
              <span class="cc-label">Lissage</span>
              <span class="cc-value tabular-nums" data-hero-target="smoothingValue">95</span>
            </div>
            <input
              type="range"
              data-hero-target="smoothing"
              data-action="input->hero#onControlInput"
              min="10"
              max="100"
              value="95"
              aria-label="Lissage"
              class="cc-slider"
            >
          </div>

          <div class="cc-pair">
            <div class="cc-row cc-row--grid">
              <div class="cc-label-row">
                <span class="cc-label">Courbe</span>
                <span class="cc-value tabular-nums" data-hero-target="curveValue">70, 90</span>
              </div>
              <div class="cc-grid"
                   data-pattern-grid="1"
                   data-controller="tooltip"
                   data-tooltip-text-value="Forme du motif">
                <div class="cc-grid__lines" data-hero-target="grid" data-pattern-grid="1"></div>
                <div class="cc-grid__handle"
                     data-hero-target="anchor1"
                     data-action="mousedown->hero#startDrag touchstart->hero#startDrag"
                     aria-label="Point de contrôle de la courbe"
                     role="slider"></div>
              </div>
            </div>

            <div class="cc-row cc-row--grid">
              <div class="cc-label-row">
                <span class="cc-label">Grille</span>
                <span class="cc-value tabular-nums" data-hero-target="gridValue">1 × 1</span>
              </div>
              <div class="cc-grid"
                   data-pattern-grid="2"
                   data-controller="tooltip"
                   data-tooltip-text-value="Répétition du motif">
                <div class="cc-grid__lines cc-grid__lines--quad" data-hero-target="grid" data-pattern-grid="2"></div>
                <div class="cc-grid__handle"
                     data-hero-target="anchor2"
                     data-action="mousedown->hero#startDrag touchstart->hero#startDrag"
                     aria-label="Densité de la grille"
                     role="slider"></div>
              </div>
            </div>
          </div>
        </div>

        <input type="range" data-hero-target="colorPicker" data-action="input->hero#onControlInput" min="0" max="360" value="243" class="hidden" aria-hidden="true" tabindex="-1">
        <input type="range" data-hero-target="firstSliderControl" value="70" min="0" max="100" class="hidden">
        <input type="range" data-hero-target="secondSliderControl" value="90" min="0" max="100" class="hidden">
        <input data-hero-target="rows" value="1" class="hidden">
        <input data-hero-target="columns" value="1" class="hidden">
      </div>
    </div>
  </div>
</div>

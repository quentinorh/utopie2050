<%# Welcoming-words loader — runs once per session and removes itself. %>
<div data-controller="welcoming-loader" class="welcoming-loader-mount"></div>

<% hero_unique_id = SecureRandom.uuid %>

<section class="hero-shell" aria-label="Introduction">
  <%# Source SVG — kept in the DOM so the hero controller can keep
      animating the symmetric pattern; the distortion canvas reads it
      every frame as a texture. The SVG itself is hidden visually
      (the shader is what the user actually sees) but stays measured
      and laid out so cloning + serialising keeps working. %>
  <div data-controller="hero"
       data-hero-unique-id-value="<%= hero_unique_id %>"
       class="hero-source"
       aria-hidden="true">
    <svg id="hero-source-svg-<%= hero_unique_id %>"
         data-hero-target="svg"
         shape-rendering="auto"
         viewBox="0 0 1920 1080"
         preserveAspectRatio="xMidYMid meet">
      <defs>
        <radialGradient id="gradient1-<%= hero_unique_id %>" cx="50%" cy="50%" r="50%">
          <stop offset="0%"/>
          <stop offset="100%"/>
        </radialGradient>
        <radialGradient id="gradient2-<%= hero_unique_id %>" cx="50%" cy="50%" r="50%">
          <stop offset="0%"/>
          <stop offset="100%"/>
        </radialGradient>
        <radialGradient id="gradient3-<%= hero_unique_id %>" cx="50%" cy="50%" r="50%">
          <stop offset="0%"/>
          <stop offset="100%"/>
        </radialGradient>

        <%# ── Reveal-from-center dissolve ──────────────────────────────
            The mask is a black field with a white radial gradient over
            it; the gradient's pixels get displaced by fractal-noise
            turbulence so the reveal edge is a ragged organic boundary
            (think erosion / dispersed particles). The hero controller
            animates the gradient's `r` attribute from 0 → ~1.4 to grow
            the visible disc out from the centre to the corners. %>
        <filter id="dissolve-<%= hero_unique_id %>"
                x="-20%" y="-20%" width="140%" height="140%"
                color-interpolation-filters="sRGB">
          <feTurbulence type="fractalNoise"
                        baseFrequency="0.011"
                        numOctaves="3"
                        seed="7"
                        result="t"/>
          <feDisplacementMap in="SourceGraphic" in2="t"
                             scale="220"
                             xChannelSelector="R"
                             yChannelSelector="G"/>
        </filter>
        <radialGradient id="reveal-grad-<%= hero_unique_id %>"
                        data-hero-target="revealGrad"
                        cx="0.5" cy="0.5" r="0" fx="0.5" fy="0.5"
                        gradientUnits="objectBoundingBox">
          <stop offset="0%"   stop-color="white" stop-opacity="1"/>
          <stop offset="65%"  stop-color="white" stop-opacity="1"/>
          <stop offset="100%" stop-color="black" stop-opacity="1"/>
        </radialGradient>
        <mask id="reveal-mask-<%= hero_unique_id %>"
              maskUnits="userSpaceOnUse"
              x="0" y="0" width="1920" height="1080">
          <rect width="1920" height="1080" fill="black"/>
          <rect width="1920" height="1080"
                fill="url(#reveal-grad-<%= hero_unique_id %>)"
                filter="url(#dissolve-<%= hero_unique_id %>)"/>
        </mask>
      </defs>
      <g data-hero-target="curveGroup"
         mask="url(#reveal-mask-<%= hero_unique_id %>)"></g>
    </svg>
  </div>

  <%# WebGL distortion overlay — samples the source SVG above and
      warps it via a fragment shader driven by mouse + flow noise. %>
  <div class="hero-distortion"
       data-controller="hero-distortion"
       data-hero-distortion-source-value="#hero-source-svg-<%= hero_unique_id %>"
       aria-hidden="true"></div>

  <div class="hero-content"
       data-controller="hero-animation">
    <div class="hidden hero-content__inner" data-hero-animation-target="content">
      <div class="hero-content__stack">
        <h1 class="hero-title text-white text-xxl lg:text-display text-center text-balance"
            data-hero-animation-target="title">
          Lire et écrire des futurs désirables
        </h1>
        <%# CTAs match the navbar pill — same pad, radius, type scale.
            Primary = filled indigo, secondary = white ghost. %>
        <div class="hero-actions" data-hero-animation-target="buttons">
          <%= link_to "Lire les futurs", posts_path,
              class: "hero-pill hero-pill--primary",
              data: { controller: "randomize-letter-animation",
                      "randomize-letter-animation-text-value": "Lire les futurs",
                      action: "mouseover->randomize-letter-animation#connect" } %>
          <%= link_to "Écrire le futur", new_post_path,
              class: "hero-pill hero-pill--ghost",
              data: { controller: "randomize-letter-animation",
                      "randomize-letter-animation-text-value": "Écrire le futur",
                      action: "mouseover->randomize-letter-animation#connect" } %>
        </div>
      </div>
    </div>
  </div>
</section>

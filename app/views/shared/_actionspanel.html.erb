<%# Floating actions panel — slides up from bottom-left %>
<div data-actions-target="actionsPanel"
     class="!hidden fixed z-50 bottom-[62px] left-4 lg:left-[calc(50%+16px)]"
     style="opacity: 0; transform: translateY(8px);">
  <div class="bg-white dark:bg-gray-900 border border-gray-950/5 dark:border-white/10 rounded-2xl shadow-lg shadow-gray-950/5 dark:shadow-none p-2 flex flex-col gap-0.5 min-w-[180px]"
       style="backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">

    <%# Share %>
    <button data-action="click->actions#toggleShare"
            class="group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-950/5 dark:hover:bg-white/5 w-full text-left"
            aria-label="Partager">
      <svg class="size-4 stroke-gray-500 group-hover:stroke-gray-900 dark:group-hover:stroke-white shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2 8v5.5a1 1 0 001 1h10a1 1 0 001-1V8"/>
        <polyline points="5 4 8 1 11 4"/>
        <line x1="8" y1="1" x2="8" y2="10"/>
      </svg>
      <span class="text-sm text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Partager</span>
    </button>

    <% if user_signed_in? %>
      <%# Favorite %>
      <%= turbo_frame_tag "favorite_button" do %>
        <% is_fav = current_user.favorites.exists?(post: @post) %>
        <%= button_to is_fav ? unfavorite_post_path(@post) : favorite_post_path(@post),
            method: is_fav ? :delete : :post,
            form_class: "w-full",
            class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-950/5 dark:hover:bg-white/5 w-full text-left cursor-pointer",
            aria_label: is_fav ? "Retirer des favoris" : "Ajouter aux favoris" do %>
          <svg class="size-4 shrink-0 <%= is_fav ? 'fill-amber-400 stroke-amber-400' : 'stroke-gray-500 group-hover:stroke-gray-900 dark:group-hover:stroke-white fill-none' %>" viewBox="0 0 16 16" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="8 1.5 10 5.5 14.5 6 11.25 9 12 13.5 8 11.25 4 13.5 4.75 9 1.5 6 6 5.5"/>
          </svg>
          <span class="text-sm text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white"><%= is_fav ? 'Retirer des favoris' : 'Ajouter aux favoris' %></span>
        <% end %>
      <% end %>
    <% end %>

    <%# Bookmark %>
    <button data-bookmark-position="<%= @bookmark&.character_position || 0 %>"
            data-action="click->bookmark#toggle"
            data-bookmark-target="actionsButton"
            class="group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-950/5 dark:hover:bg-white/5 w-full text-left"
            aria-label="Marque-page">
      <svg class="size-4 stroke-gray-500 group-hover:stroke-gray-900 dark:group-hover:stroke-white shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 2.5h10v13L8 12l-5 3.5V2.5z"/>
      </svg>
      <span class="text-sm text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Marque-page</span>
    </button>

    <%# Divider %>
    <div class="mx-2 border-t border-gray-950/5 dark:border-white/10 my-0.5"></div>

    <%# Report %>
    <button data-action="click->actions#toggleReport"
            class="group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-950/5 dark:hover:bg-white/5 w-full text-left"
            aria-label="Signaler">
      <svg class="size-4 stroke-gray-500 group-hover:stroke-gray-900 dark:group-hover:stroke-white shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M2.5 14.5V2l9 1v6l-9 1"/>
      </svg>
      <span class="text-sm text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Signaler</span>
    </button>

    <% if user_signed_in? && current_user == @post.user %>
      <%# Edit %>
      <%= link_to edit_post_path(@post),
          class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-950/5 dark:hover:bg-white/5 w-full text-left",
          aria_label: "Modifier" do %>
        <svg class="size-4 stroke-gray-500 group-hover:stroke-gray-900 dark:group-hover:stroke-white shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M11 2.5l2.5 2.5L5 13.5H2.5V11z"/>
        </svg>
        <span class="text-sm text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Modifier</span>
      <% end %>

      <%# Delete %>
      <button data-action="click->actions#toggleDelete"
              class="group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-red-50 dark:hover:bg-red-950/20 w-full text-left"
              aria-label="Supprimer">
        <svg class="size-4 stroke-gray-500 group-hover:stroke-red-600 shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 4h10M6 4V2.5h4V4M4.5 4v9a1 1 0 001 1h5a1 1 0 001-1V4"/>
        </svg>
        <span class="text-sm text-gray-600 group-hover:text-red-600 dark:text-gray-300">Supprimer</span>
      </button>
    <% end %>
  </div>
</div>

<%= render "shared/actions" %>

<%# Rendered as a turbo_stream replacement after a "favorite" POST.
    The controller pulses the star icon on mount (fresh: true). %>
<%= turbo_frame_tag "favorite_button" do %>
  <%= button_to unfavorite_post_path(post),
      method: :delete,
      form_class: "w-full",
      form: {
        data: {
          controller: "favorite-pulse",
          favorite_pulse_state_value: "favorited",
          favorite_pulse_fresh_value: true
        }
      },
      class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-950/5 dark:hover:bg-white/5 w-full text-left cursor-pointer",
      data: { tap: "" },
      aria_label: "Retirer des favoris" do %>
    <svg class="size-4 shrink-0 fill-amber-400 stroke-amber-400"
         data-favorite-pulse-target="icon"
         viewBox="0 0 16 16"
         stroke-width="1.5"
         stroke-linecap="round"
         stroke-linejoin="round">
      <polygon points="8 1.5 10 5.5 14.5 6 11.25 9 12 13.5 8 11.25 4 13.5 4.75 9 1.5 6 6 5.5"/>
    </svg>
    <span class="text-sm text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Retirer des favoris</span>
  <% end %>
<% end %>

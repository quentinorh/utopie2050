<%# Rendered as a turbo_stream replacement after an "unfavorite"
    DELETE. Pulses the star with the soft pop-in keyframe to confirm
    the change in state. %>
<%= turbo_frame_tag "favorite_button" do %>
  <%= button_to favorite_post_path(post),
      method: :post,
      form_class: "w-full",
      form: {
        data: {
          controller: "favorite-pulse",
          favorite_pulse_state_value: "unfavorited",
          favorite_pulse_fresh_value: true
        }
      },
      class: "group flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-950/5 dark:hover:bg-white/5 w-full text-left cursor-pointer",
      data: { tap: "" },
      aria_label: "Ajouter aux favoris" do %>
    <svg class="size-4 shrink-0 stroke-gray-500 group-hover:stroke-gray-900 dark:group-hover:stroke-white fill-none"
         data-favorite-pulse-target="icon"
         viewBox="0 0 16 16"
         stroke-width="1.5"
         stroke-linecap="round"
         stroke-linejoin="round">
      <polygon points="8 1.5 10 5.5 14.5 6 11.25 9 12 13.5 8 11.25 4 13.5 4.75 9 1.5 6 6 5.5"/>
    </svg>
    <span class="text-sm text-gray-600 dark:text-gray-300 group-hover:text-gray-900 dark:group-hover:text-white">Ajouter aux favoris</span>
  <% end %>
<% end %>

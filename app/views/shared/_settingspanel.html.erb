<%# Reading settings popover — slides up from bottom-right %>
<div data-actions-target="settingsPanel"
     class="!hidden fixed z-50 bottom-[62px] right-4"
     style="opacity: 0; transform: translateY(8px);">
  <div class="bg-white dark:bg-gray-900 border border-gray-950/5 dark:border-white/10 rounded-2xl shadow-lg shadow-gray-950/5 dark:shadow-none p-4 w-[280px]"
       style="backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">

    <%# Text size %>
    <div class="mb-4">
      <span class="font-mono text-[10px] uppercase tracking-widest text-gray-400 dark:text-gray-500">Taille</span>
      <div class="flex gap-1.5 mt-2">
        <% %w[small medium large xlarge].each_with_index do |size, i| %>
          <button class="flex-1 h-8 flex items-center justify-center rounded-lg border border-transparent hover:bg-gray-950/5 dark:hover:bg-white/5"
                  data-action="click->actions#changeTextSize"
                  data-actions-target="textSize"
                  data-value="<%= size %>"
                  aria-label="Taille <%= size %>">
            <span class="text-gray-600 dark:text-gray-300" style="font-size: <%= [11, 13, 15, 17][i] %>px;">A</span>
          </button>
        <% end %>
      </div>
    </div>

    <%# Line height %>
    <div class="mb-4">
      <span class="font-mono text-[10px] uppercase tracking-widest text-gray-400 dark:text-gray-500">Interligne</span>
      <div class="flex gap-1.5 mt-2">
        <% %w[small medium large xlarge].each_with_index do |lh, i| %>
          <button class="flex-1 h-8 flex items-center justify-center rounded-lg border border-transparent hover:bg-gray-950/5 dark:hover:bg-white/5"
                  data-action="click->actions#changeLineHeight"
                  data-actions-target="lineHeight"
                  data-value="<%= lh %>"
                  aria-label="Interligne <%= lh %>">
            <svg class="size-4 stroke-gray-500 shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round">
              <line x1="3" y1="<%= [3, 2, 1, 0.5][i] %>" x2="13" y2="<%= [3, 2, 1, 0.5][i] %>"/>
              <line x1="3" y1="8" x2="13" y2="8"/>
              <line x1="3" y1="<%= [13, 14, 15, 15.5][i] %>" x2="13" y2="<%= [13, 14, 15, 15.5][i] %>"/>
            </svg>
          </button>
        <% end %>
      </div>
    </div>

    <%# Font %>
    <div class="mb-4">
      <span class="font-mono text-[10px] uppercase tracking-widest text-gray-400 dark:text-gray-500">Police</span>
      <div class="flex gap-1.5 mt-2">
        <button class="flex-1 h-8 flex items-center justify-center rounded-lg border border-transparent hover:bg-gray-950/5 dark:hover:bg-white/5 text-sm font-sans text-gray-600 dark:text-gray-300"
                data-action="click->actions#changeFont"
                data-actions-target="font"
                data-value="sans">Apfel</button>
        <button class="flex-1 h-8 flex items-center justify-center rounded-lg border border-transparent hover:bg-gray-950/5 dark:hover:bg-white/5 text-sm font-lexend text-gray-600 dark:text-gray-300"
                data-action="click->actions#changeFont"
                data-actions-target="font"
                data-value="Lexend">Lexend</button>
      </div>
    </div>

    <%# Theme %>
    <div>
      <span class="font-mono text-[10px] uppercase tracking-widest text-gray-400 dark:text-gray-500">Mode</span>
      <div class="flex gap-1.5 mt-2">
        <button class="flex-1 h-8 flex items-center justify-center gap-2 rounded-lg border border-transparent hover:bg-gray-950/5 dark:hover:bg-white/5"
                data-action="click->actions#changePostTheme"
                data-actions-target="theme"
                data-value="light"
                aria-label="Mode clair">
          <svg class="size-4 stroke-gray-500 shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round">
            <circle cx="8" cy="8" r="3"/>
            <line x1="8" y1="1" x2="8" y2="3"/><line x1="8" y1="13" x2="8" y2="15"/>
            <line x1="1" y1="8" x2="3" y2="8"/><line x1="13" y1="8" x2="15" y2="8"/>
            <line x1="3.05" y1="3.05" x2="4.46" y2="4.46"/><line x1="11.54" y1="11.54" x2="12.95" y2="12.95"/>
            <line x1="3.05" y1="12.95" x2="4.46" y2="11.54"/><line x1="11.54" y1="4.46" x2="12.95" y2="3.05"/>
          </svg>
          <span class="text-sm text-gray-600 dark:text-gray-300">Clair</span>
        </button>
        <button class="flex-1 h-8 flex items-center justify-center gap-2 rounded-lg border border-transparent hover:bg-gray-950/5 dark:hover:bg-white/5"
                data-action="click->actions#changePostTheme"
                data-actions-target="theme"
                data-value="dark"
                aria-label="Mode sombre">
          <svg class="size-4 stroke-gray-500 shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 9.5A6 6 0 016.5 2 6 6 0 1014 9.5z"/>
          </svg>
          <span class="text-sm text-gray-600 dark:text-gray-300">Sombre</span>
        </button>
      </div>
    </div>
  </div>
</div>

<nav class="fixed bottom-0 left-0 z-[99] w-full lg:w-1/2 lg:left-1/2 min-[1440px]:w-[60%] min-[1440px]:left-[40%] h-[50px]"
     style="backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">
  <div class="absolute inset-0 bg-white/80 dark:bg-gray-900/80 border-t border-gray-950/5 dark:border-white/10"></div>

  <div class="relative flex items-center h-full px-4 lg:px-12">
    <!-- Left: Actions toggle -->
    <button data-action="click->actions#toggleActions"
            class="relative group size-10 flex items-center justify-center rounded-full"
            aria-label="Menu des actions">
      <svg class="size-4 stroke-gray-400 group-hover:stroke-gray-900 dark:group-hover:stroke-white shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round">
        <line x1="2" y1="4" x2="14" y2="4"/>
        <line x1="2" y1="8" x2="14" y2="8"/>
        <line x1="2" y1="12" x2="14" y2="12"/>
      </svg>
    </button>

    <!-- Center: Scroll percentage -->
    <div class="flex-1 flex justify-center">
      <span class="font-mono text-xs tracking-wide text-gray-400 tabular-nums">
        <span data-scroll-target="scrollPercentage">0</span><span class="text-gray-300 dark:text-gray-600">%</span>
      </span>
    </div>

    <!-- Right: Bookmark + Settings -->
    <div class="flex items-center gap-1">
      <button class="relative group hidden size-10 flex items-center justify-center rounded-full"
              data-bookmark-position="<%= @bookmark&.character_position || 0 %>"
              data-action="click->bookmark#toggle"
              data-bookmark-target="button"
              aria-label="Marque-page">
        <svg class="size-4 stroke-gray-400 group-hover:stroke-gray-900 dark:group-hover:stroke-white shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 2.5h10v13L8 12l-5 3.5V2.5z"/>
        </svg>
      </button>

      <button data-action="click->actions#toggleSettings"
              class="relative group size-10 flex items-center justify-center rounded-full"
              aria-label="Paramètres d'affichage">
        <svg class="size-4 stroke-gray-400 group-hover:stroke-gray-900 dark:group-hover:stroke-white shrink-0" viewBox="0 0 16 16" fill="none" stroke-width="1.5" stroke-linecap="round">
          <line x1="2" y1="4" x2="14" y2="4"/>
          <line x1="2" y1="12" x2="14" y2="12"/>
          <circle cx="5" cy="4" r="1.5" fill="currentColor" class="fill-gray-400 group-hover:fill-gray-900 dark:group-hover:fill-white"/>
          <circle cx="11" cy="12" r="1.5" fill="currentColor" class="fill-gray-400 group-hover:fill-gray-900 dark:group-hover:fill-white"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

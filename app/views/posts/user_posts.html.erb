<% content_for :title, "SP 2050 - Mes Futurs" %>
<% content_for :description, "Découvrez tous mes futurs." %>
<% content_for :meta_robots, "noindex, nofollow" %>

<div class="flex flex-col min-h-screen">
  <div class="w-full grow min-w-0">
    <div class="flex flex-row justify-between items-center p-xs sticky top-[theme('top.navbar-height')] z-20 bg-white">
      <h1 class="text-2l lg:text-display items-center flex">Mes futurs
        <div class="font-mono text-base md:text-2xl inline-flex items-center ml-xxs">
          <span>[</span>
          <div data-controller="randomize-letter-animation" data-randomize-letter-animation-text-value="<%= @user_posts.count %>"><%= @user_posts.count %></div>
          <span>]</span>
        </div>
      </h1>
    </div>

    <div class="m-auto justify-center p-xs pt-0">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-xs grow justify-center" data-controller="staggered-animation">
        <% if @user_posts.any? %>
          <% @user_posts.order(created_at: :desc).each do |post| %>
            <div class="relative">
              <%= render "posts/post", post: post %>
              <div class="absolute inset-0 pointer-events-none z-10">
                <div class="absolute top-2 right-2 pointer-events-auto">
                  <% if post.draft? %>
                    <span class="inline-flex items-center gap-1 bg-indigo-600 text-white text-xs font-mono px-2 py-1 rounded-full shadow">
                      <span class="w-1.5 h-1.5 bg-white rounded-full"></span>
                      Brouillon
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 bg-indigo-600 text-white text-xs font-mono px-2 py-1 rounded-full shadow">
                      <span class="w-1.5 h-1.5 bg-white rounded-full"></span>
                      Publié
                    </span>
                  <% end %>
                </div>
                <div class="absolute top-2 left-2 pointer-events-auto flex gap-1">
                  <%= link_to edit_post_path(post),
                      class: "inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/90 backdrop-blur-sm border border-gray-300 text-gray-800 hover:bg-gray-50 transition-colors shadow-sm",
                      title: "Éditer",
                      aria: { label: "Éditer ce futur" } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  <% end %>
                  <%= link_to post_path(post),
                      data: { turbo_method: :delete, turbo_confirm: "Es-tu sûr·e de vouloir supprimer ce futur ?" },
                      class: "inline-flex items-center justify-center w-9 h-9 rounded-full bg-white/90 backdrop-blur-sm border border-red-300 text-red-600 hover:bg-red-50 transition-colors shadow-sm",
                      title: "Supprimer",
                      aria: { label: "Supprimer ce futur" } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="col-span-full text-center py-lg">
            <p class="text-gray-500 text-lg">Tu n'as pas encore créé de futurs.</p>
            <%= link_to "Écrire mon premier futur", new_post_path, class: "mt-sm inline-block tw-btn-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

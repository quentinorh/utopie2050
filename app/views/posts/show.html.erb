<% content_for :navbar_transparent, true %>
<% content_for :title, "SP 2050 - #{@post.title}" %>
<% content_for :description, truncate(strip_tags(@post.body), length: 160) %>

<% content_for :meta_tags do %>
  <%# Meta pour les articles %>
  <meta property="article:published_time" content="<%= @post.created_at.iso8601 %>">
  <meta property="article:author" content="<%= @post.user.username %>">
  
  <%# Balises Open Graph et Twitter %>
  <meta property="og:type" content="article">
  <meta property="og:title" content="<%= @post.title %>">
  <meta property="og:description" content="<%= truncate(strip_tags(@post.body), length: 160) %>">
  <meta property="og:image" content="<%= @post.social_image_url %>">
  <meta name="twitter:image" content="<%= @post.social_image_url %>">
  
  <%# URL canonique %>
  <link rel="canonical" href="<%= post_url(@post, host: 'votre-domaine.fr') %>" />
<% end %>

<div data-controller="scroll cover actions svg-animation bookmark"
     data-post-id="<%= @post.id %>"
     data-cover-hue-value="<%= @post.pattern_settings.present? ? JSON.parse(@post.pattern_settings)['hue'] : 0 %>"
     data-cover-pattern-settings-value="<%= @post.pattern_settings %>">

  <input type="hidden" data-cover-target="title" value="<%= @post.title %>">
  <input type="hidden" data-cover-target="patternSettings" value="<%= @post.pattern_settings %>">

  <%= render 'shared/settingspanel' %>
  <%= render 'shared/actionspanel' %>

  <div class="flex flex-col lg:flex-row dark:bg-gray-800 bg-gray-100">
    <!-- Cover panel (left, fixed on desktop) -->
    <div class="cover opacity-0">
      <%= render 'posts/cover', post: @post, ratio: "4x5" %>
    </div>

    <!-- Content panel (right, scrollable) -->
    <div class="show-content-panel bg-gray-100 dark:bg-gray-800 text-black-900 dark:text-gray-100">
      <!-- Metadata row -->
      <div class="show-metadata flex w-full justify-between items-baseline font-mono uppercase tracking-wide py-sm lg:py-[18px]">
        <div class="show-metadata__group">
          <span>Publié le</span>
          <span class="tabular-nums" data-controller="randomize-letter-animation" data-randomize-letter-animation-text-value="<%= @post.created_at.strftime("%d.%m.%Y") %>"><%= @post.created_at.strftime("%d.%m.%Y") %></span>
        </div>
        <div class="show-metadata__group">
          <span class="max-lg:hidden">Temps de lecture</span>
          <span class="lg:hidden">Lecture</span>
          <span class="tabular-nums"><%= @post.calculate_reading_time %></span>
        </div>
      </div>

      <div class="show-separator border-t border-gray-950/10 dark:border-white/10"></div>

      <% if @post.event_code_details %>
        <div class="w-1/2 font-mono text-xs mt-sm">
          <% if @post.event_code_details[:link].present? %>
            <%= link_to @post.event_code_details[:link],
                        class: "text-xs",
                        target: "_blank",
                        style: "color: #{@post.event_code_details[:color]};" do %>
              <%= @post.event_code_details[:text] %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <!-- Post body -->
      <div class="post-body"
           data-controller="text-reveal"
           data-text-reveal-mode-value="lines"
           data-scroll-target="content">
        <div class="body-content mt-[24px] lg:mt-sm adjustable w-full whitespace-pre-wrap"><%= @post.body %></div>
        <% if @post.chapters.any? %>
          <div class="adjustable w-full pt-0 transition-opacity duration-1000" data-scroll-target="content">
            <% @post.chapters.each_with_index do |chapter, index| %>
              <div class="mt-lg">
                <h2 class="chapter-title text-2xl mt-8 mb-4">
                  Chapitre <%= index + 1 %> : <%= chapter.title %>
                </h2>
                <div class="chapter-content mt-0 whitespace-pre-wrap"><%= chapter.body %></div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Spacer for bottom bar %>
      <div class="h-[80px]"></div>
    </div>
  </div>

  <%= render 'shared/bottomnavbar' %>
</div>
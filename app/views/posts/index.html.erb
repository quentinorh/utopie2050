<% content_for :title, "SP 2050 - Explorer les futurs désirables" %>
<% content_for :description, "Découvre notre collection de futurs. Des récits qui imaginent un futur durable, écologique et socialement juste. Laisse-toi inspirer par les visions de nos auteur·ice·s." %>

<div data-controller="filter page-transition">
  <!-- Title section -->
  <div class="index-title-section">
    <h1 class="index-title"><%= @filters_active ? "Futurs trouvés" : "Tous les futurs" %><span class="index-title-count font-mono">[<span data-controller="randomize-letter-animation" data-randomize-letter-animation-text-value="<%= @posts.count %>"><%= @posts.count %></span>]</span></h1>
  </div>

  <!-- Separator -->
  <div class="border-t border-black"></div>

  <!-- Posts grid -->
  <div id="posts-grid">
    <div class="index-grid" data-controller="staggered-animation">
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <%= render "posts/post", post: post %>
        <% end %>
      <% else %>
        <p class="col-span-3 text-center text-gray-500 py-lg">Aucun futur n'a été trouvé.</p>
      <% end %>
    </div>
  </div>

  <!-- Filter panel (hidden by default, toggle on mobile) -->
  <div data-filter-visible-class="translate-y-[theme('top.navbar-height')]"
       data-filter-hidden-class=""
       data-filter-target="panel"
       class="fixed right-0 h-[calc(100dvh-theme('top.navbar-height'))] top-[theme('top.navbar-height')] translate-x-full lg:translate-x-0 w-full lg:w-1/4 z-10 p-xs transition duration-[650ms] ease-bezier-fast border-l border-gray-300 bg-white overflow-y-auto hidden">
    <div data-filter-target="panel">
      <div class="block flex items-center justify-between pb-xs">
        <span class="text-gray-900 text-2l block">Filtres</span>
      </div>
      <%= form_with url: posts_path, method: :get, html: { data: { turbo: true, turbo_stream: true, controller: "search", "turbo-frame": "posts", "turbo-action": "advance" } } do %>
        <%= label_tag :by_query, "Mot-clé", class: "mt-sm md:mt-0 text-base mb-xxs block" %>
        <%= text_field_tag :by_query,
            params[:by_query],
            class: "tw-form-input",
            placeholder: "Rechercher...",
            "aria-label": "Rechercher des articles",
            data: { action: "input->search#submit" }
        %>
        <%= label_tag :by_author, "Auteur·ice·s", class: "text-base mb-xxs block mt-sm" %>
        <%= select_tag :by_author,
            options_from_collection_for_select(User.has_posts, "id", "username", params[:by_author]),
            prompt: "Sélectionner...",
            class: "tw-form-input",
            "aria-label": "Filtrer par auteur",
            label_class: "tw-form-label",
            data: { action: "change->search#submit" } %>
        <div class="mt-4 flex gap-4 items-center">
          <div class="w-full">
            <label class="mt-sm md:mt-0 text-base">Temps de lecture (minutes)</label>
            <div class="mt-xs px-2 flex flex-col gap-2">
              <div id="reading-time-slider"
                   class="w-full relative h-2 bg-gray-200 rounded-lg tailwind-slider"
                   data-controller="slider"
                   data-slider-max-value="<%= @max_reading_time %>"
                   data-slider-min-value="0">
              </div>
              <div class="flex justify-between text-sm">
                <span id="min-time-value"><%= params[:min_reading_time] || 0 %></span>
                <span id="max-time-value"><%= params[:max_reading_time] || @max_reading_time %></span>
              </div>
              <%= hidden_field_tag "by_reading_time_range[min]",
                  params.dig(:by_reading_time_range, :min) || 0,
                  data: { action: "change->search#submit" } %>
              <%= hidden_field_tag "by_reading_time_range[max]",
                  params.dig(:by_reading_time_range, :max) || @max_reading_time,
                  data: { action: "change->search#submit" } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% if params[:page].present? && params[:page].to_i > 1 %>
  <% content_for :meta_robots, "noindex, follow" %>
<% end %>

<% if params[:by_query].present? || params[:by_author].present? || params[:by_reading_time_range].present? %>
  <% content_for :meta_robots, "noindex, follow" %>
<% end %>

<% content_for :canonical_url do %>
  <link rel="canonical" href="<%= posts_url %>" />
<% end %>

<% unique_id = @post.persisted? ? @post.id : SecureRandom.uuid %>
<div data-controller="chapter test"
     data-preview-username-value="<%= current_user.username %>"
     data-preview-initial-hue-value="<%= @post.pattern_settings.try(:[], 'hue') || rand(360) %>"
     data-test-unique-id-value="<%= unique_id %>"
     data-test-pattern-settings-value="<%= @post.pattern_settings.to_json %>"
     class="w-full form-editor">
  <%= form_with(model: @post, local: true, html: { multipart: true, class: "flex flex-col min-h-screen", data: { action: "submit->test#saveSVG submit->test#savePatternSettings" } }) do |form| %>

    <% if @post.errors.any? %>
      <div class="editor-errors" role="alert">
        <p class="editor-errors__title"><%= pluralize(@post.errors.count, "erreur") %> ont empêché ce post d'être sauvegardé</p>
        <ul role="list" class="editor-errors__list">
          <% @post.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex flex-col flex-1">
      <!-- Colonne de gauche : couverture + carte de contrôles flottante -->
      <aside class="form-left-panel">
        <div class="form-cover-wrapper">
          <div class="form-cover-svg form-cover-svg--editor" data-controller="coversize">
            <svg data-coversize-target="svg" class="cover-svg" shape-rendering="auto" viewBox="0 0 250 350" preserveAspectRatio="xMidYMid slice">
              <defs>
                <radialGradient id="gradient1-<%= unique_id %>" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"/>
                  <stop offset="100%"/>
                </radialGradient>
                <radialGradient id="gradient2-<%= unique_id %>" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"/>
                  <stop offset="100%"/>
                </radialGradient>
                <radialGradient id="gradient3-<%= unique_id %>" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"/>
                  <stop offset="100%"/>
                </radialGradient>
              </defs>
              <g data-test-target="curveGroup"></g>
            </svg>

            <!-- Cover title block — typesetting identique à la page show -->
            <div class="cover-title-block pointer-events-none">
              <div class="cover-username" data-test-target="userName">
                <%= current_user.username %>
              </div>
              <div class="cover-title-text" data-test-target="titleWrapper"></div>
            </div>

            <!-- Bouton aléatoire -->
            <button type="button"
                    class="editor-randomize"
                    data-action="click->test#randomize"
                    aria-label="Générer une couverture aléatoire">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" class="size-3.5" aria-hidden="true">
                <path d="M2 5h6.5a4 4 0 014 4v2M14 11l-2-2M14 11l-2 2M14 11h-2"/>
                <path d="M14 5L2 5M2 5l2-2M2 5l2 2"/>
              </svg>
              <span>Aléatoire</span>
            </button>
          </div>
        </div>

        <!-- Carte de contrôles flottante (popover-style, skeuomorphique N&B) -->
        <div class="cover-controls" data-test-target="controlsCard">
          <button type="button"
                  class="cover-controls__head"
                  data-action="click->test#toggleControls"
                  aria-expanded="true"
                  aria-controls="cover-controls-body">
            <span class="cover-controls__title">Paramètres de la couverture</span>
            <svg xmlns="http://www.w3.org/2000/svg"
                 class="cover-controls__chev"
                 data-test-target="controlsToggleIcon"
                 viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
              <polyline points="4 10 8 6 12 10"/>
            </svg>
          </button>

          <div class="cover-controls__body" id="cover-controls-body">
            <!-- SYMÉTRIE -->
            <div class="cc-row">
              <span class="cc-label">Symétrie</span>
              <div class="cc-segmented" role="radiogroup" aria-label="Symétrie">
                <button type="button"
                        class="cc-segmented__btn"
                        data-test-target="symmetryMode"
                        data-action="click->test#updateCurve"
                        data-value="x4"
                        role="radio">×4</button>
                <button type="button"
                        class="cc-segmented__btn"
                        data-test-target="symmetryMode"
                        data-action="click->test#updateCurve"
                        data-value="x8"
                        role="radio">×8</button>
                <button type="button"
                        class="cc-segmented__btn"
                        data-test-target="symmetryMode"
                        data-action="click->test#updateCurve"
                        data-value="x16"
                        role="radio">×16</button>
              </div>
            </div>

            <!-- TEINTE -->
            <div class="cc-row">
              <div class="cc-label-row">
                <span class="cc-label">Teinte</span>
                <span class="cc-value tabular-nums" data-test-target="hueValue">280°</span>
              </div>
              <input
                type="range"
                id="hue"
                data-test-target="colorPicker"
                data-action="input->test#updateColors input->test#updateTitle input->test#updateCurve input->test#updateValueDisplays"
                min="0"
                max="360"
                value="280"
                aria-label="Teinte"
                class="cc-slider cc-slider--hue"
              >
            </div>

            <!-- LISSAGE -->
            <div class="cc-row">
              <div class="cc-label-row">
                <span class="cc-label">Lissage</span>
                <span class="cc-value tabular-nums" data-test-target="smoothingValue">50</span>
              </div>
              <input
                type="range"
                data-test-target="smoothing"
                data-action="input->test#updateCurve input->test#updateValueDisplays"
                min="10"
                max="100"
                value="50"
                aria-label="Lissage"
                class="cc-slider"
              >
            </div>

            <!-- COURBE + GRILLE (deux mini-grilles côte à côte) -->
            <div class="cc-pair">
              <div class="cc-row cc-row--grid">
                <div class="cc-label-row">
                  <span class="cc-label">Courbe</span>
                  <span class="cc-value tabular-nums" data-test-target="curveValue">50, 50</span>
                </div>
                <div class="cc-grid" data-pattern-grid="1">
                  <div class="cc-grid__lines" data-test-target="grid" data-pattern-grid="1"></div>
                  <div class="cc-grid__handle"
                       data-test-target="anchor1"
                       data-action="mousedown->test#startDrag touchstart->test#startDrag mousemove->test#drag touchmove->test#drag mouseup->test#stopDrag touchend->test#stopDrag"
                       aria-label="Point de contrôle de la courbe"
                       role="slider"></div>
                </div>
              </div>

              <div class="cc-row cc-row--grid">
                <div class="cc-label-row">
                  <span class="cc-label">Grille</span>
                  <span class="cc-value tabular-nums" data-test-target="gridValue">2 × 2</span>
                </div>
                <div class="cc-grid" data-pattern-grid="2">
                  <div class="cc-grid__lines cc-grid__lines--quad" data-test-target="grid" data-pattern-grid="2"></div>
                  <div class="cc-grid__handle"
                       data-test-target="anchor2"
                       data-action="mousedown->test#startDrag touchstart->test#startDrag mousemove->test#drag touchmove->test#drag mouseup->test#stopDrag touchend->test#stopDrag"
                       aria-label="Densité de la grille"
                       role="slider"></div>
                </div>
              </div>
            </div>

            <input type="range" data-test-target="firstSliderControl" data-action="input->test#updateCurve" class="hidden">
            <input type="range" data-test-target="secondSliderControl" data-action="input->test#updateCurve" class="hidden">
            <input data-test-target="rows" data-action="input->test#updateCurve" class="hidden">
            <input data-test-target="columns" data-action="input->test#updateCurve" class="hidden">
            <%= form.hidden_field :pattern_settings, data: { test_target: "patternSettings" } %>
            <%= form.hidden_field :cover, data: { test_target: "cover" } %>
          </div>
        </div>
      </aside>

      <!-- Colonne de droite : contenu -->
      <main class="form-right-panel">
        <div class="editor-body">
          <!-- Titre du futur — input minimaliste, gros caractères -->
          <div class="editor-title-field">
            <label for="post_title" class="sr-only">Titre du futur</label>
            <%= form.text_field :title,
                                id: "post_title",
                                class: "editor-title-input",
                                placeholder: "Ton futur titre…",
                                value: @post.title,
                                required: true,
                                data: { action: "input->test#updateTitle", test_target: "titleInput" } %>
            <p class="editor-error mt-2 hidden" data-preview-target="titleError">Le titre est requis</p>
          </div>

          <!-- Code événement — discret, sous le titre -->
          <div class="editor-meta-row">
            <label class="editor-field">
              <span class="editor-field__label font-mono">Code événement</span>
              <%= form.text_field :event_code,
                                  value: @post.event_code&.code,
                                  class: "editor-input editor-input--compact",
                                  placeholder: "Optionnel" %>
            </label>
          </div>

          <!-- Corps du texte -->
          <div class="editor-body-field">
            <label for="post_body" class="editor-section-label font-mono">Texte d'introduction</label>
            <%= form.text_area :body,
                               id: "post_body",
                               class: "editor-textarea",
                               rows: 12,
                               placeholder: "Écris ton futur ici…" %>
          </div>

          <!-- Chapitres -->
          <section class="chapters" aria-labelledby="chapters-title">
            <header class="chapters__header">
              <div class="chapters__title-group">
                <h2 id="chapters-title" class="chapters__title font-mono">Chapitres</h2>
                <span class="chapters__count font-mono tabular-nums" data-chapter-target="count">00</span>
              </div>
              <p class="chapters__hint">Découpe ton récit en chapitres pour le rendre plus lisible.</p>
            </header>

            <div id="chapters" class="chapters__list" data-chapter-target="chapters">
              <%= form.fields_for :chapters do |chapter_form| %>
                <article class="chapter-card" data-chapter-target="chapter">
                  <header class="chapter-card__header">
                    <div class="chapter-card__index font-mono">
                      <span aria-hidden="true">Chapitre</span>
                      <span class="tabular-nums" data-chapter-target="chapterNumber">1</span>
                    </div>
                    <button type="button"
                            class="chapter-card__delete"
                            data-action="click->chapter#removeChapter"
                            aria-label="Supprimer ce chapitre">
                      <svg viewBox="0 0 16 16" class="size-3.5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M3 3l10 10M13 3L3 13"/>
                      </svg>
                    </button>
                  </header>
                  <div class="hidden" data-chapter-target="chapterIndex">
                    <%= chapter_form.options[:child_index] %>
                  </div>

                  <%= chapter_form.text_field :title,
                                              class: "chapter-card__title-input",
                                              placeholder: "Titre du chapitre" %>
                  <%= chapter_form.text_area :body,
                                             class: "chapter-card__body-input",
                                             rows: 6,
                                             placeholder: "Texte du chapitre…" %>

                  <%= chapter_form.hidden_field :position %>
                  <%= chapter_form.hidden_field :_destroy %>
                </article>
              <% end %>
            </div>

            <button type="button"
                    class="chapters__add"
                    data-action="click->chapter#addChapter">
              <span class="chapters__add-icon" aria-hidden="true">+</span>
              <span>Ajouter un chapitre</span>
            </button>
          </section>
        </div>

        <!-- Barre d'action sticky bas (vibe bottomnavbar) -->
        <footer class="editor-actionbar">
          <div class="editor-actionbar__inner">
            <div class="editor-actionbar__meta font-mono">
              <span class="editor-actionbar__type"><%= @post.new_record? ? "Nouveau futur" : "Édition" %></span>
              <% if !@post.new_record? %>
                <span aria-hidden="true">·</span>
                <span class="tabular-nums">Crée le <%= @post.created_at.strftime("%d.%m.%Y") %></span>
              <% end %>
            </div>

            <div class="editor-actionbar__actions">
              <% draft_checked = @post.draft ? 'true' : 'false' %>
              <% translate_class = @post.draft ? 'translate-x-full' : 'translate-x-0' %>
              <% switch_state_class = @post.draft ? 'is-on' : '' %>
              <div class="editor-toggle">
                <span class="editor-toggle__label">Brouillon</span>
                <button type="button"
                        class="editor-toggle__switch <%= switch_state_class %>"
                        role="switch"
                        aria-checked="<%= draft_checked %>"
                        data-action="click->test#toggleDraft">
                  <span class="sr-only">Publier comme brouillon</span>
                  <span aria-hidden="true" class="editor-toggle__thumb <%= translate_class %>"></span>
                </button>
                <%= form.hidden_field :draft, value: @post.draft, data: { test_target: "draft" } %>
              </div>

              <% submit_label = @post.new_record? ? "Publier" : "Éditer" %>
              <%= form.submit submit_label, class: "editor-btn editor-btn--primary", data: { action: "click->preview#validateForm" } %>
            </div>
          </div>
        </footer>
      </main>
    </div>
  <% end %>
</div>

<script>
  // Empêcher la propagation du scroll depuis les textarea vers la page
  document.addEventListener('wheel', function(e) {
    const textarea = e.target.closest('textarea');
    if (textarea) {
      const { scrollTop, scrollHeight, clientHeight } = textarea;
      const isAtTop = scrollTop === 0;
      const isAtBottom = scrollTop + clientHeight >= scrollHeight - 1;

      if ((e.deltaY < 0 && isAtTop) || (e.deltaY > 0 && isAtBottom)) {
        e.preventDefault();
      } else {
        e.stopPropagation();
      }
    }
  }, { passive: false });
</script>

<% unique_id = @post.persisted? ? @post.id : SecureRandom.uuid %>
<div data-controller="chapter cover-editor editor-reveal"
     data-preview-username-value="<%= current_user.username %>"
     data-preview-initial-hue-value="<%= @post.pattern_settings.try(:[], 'hue') || rand(360) %>"
     data-cover-editor-unique-id-value="<%= unique_id %>"
     data-cover-editor-new-record-value="<%= @post.new_record? ? 'true' : 'false' %>"
     data-cover-editor-pattern-settings-value="<%= @post.pattern_settings.to_json %>"
     class="w-full form-editor is-revealing">
  <%= form_with(model: @post, local: true, html: { multipart: true, class: "flex flex-col min-h-screen", data: { action: "submit->cover-editor#saveSVG submit->cover-editor#savePatternSettings" } }) do |form| %>

    <% if @post.errors.any? %>
      <div class="editor-errors" role="alert">
        <p class="editor-errors__title"><%= pluralize(@post.errors.count, "erreur") %> ont empêché ce post d'être sauvegardé</p>
        <ul role="list" class="editor-errors__list">
          <% @post.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="flex flex-col flex-1">
      <!-- Colonne de gauche : couverture + carte de contrôles flottante -->
      <aside class="form-left-panel">
        <div class="form-cover-wrapper">
          <div class="form-cover-svg form-cover-svg--editor" data-controller="coversize">
            <svg data-coversize-target="svg" class="cover-svg" shape-rendering="auto" viewBox="0 0 250 350" preserveAspectRatio="xMidYMid slice">
              <defs>
                <radialGradient id="gradient1-<%= unique_id %>" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"/>
                  <stop offset="100%"/>
                </radialGradient>
                <radialGradient id="gradient2-<%= unique_id %>" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"/>
                  <stop offset="100%"/>
                </radialGradient>
                <radialGradient id="gradient3-<%= unique_id %>" cx="50%" cy="50%" r="50%">
                  <stop offset="0%"/>
                  <stop offset="100%"/>
                </radialGradient>
              </defs>
              <g data-cover-editor-target="curveGroup"></g>
            </svg>

            <!-- Cover title block — typesetting identique à la page show -->
            <div class="cover-title-block pointer-events-none left-xs sm:left-sm lg:left-[40px] bottom-xs sm:bottom-sm lg:bottom-[40px]">
              <div class="cover-username" data-cover-editor-target="userName">
                <%= current_user.username %>
              </div>
              <div class="cover-title-text" data-cover-editor-target="titleWrapper"></div>
            </div>
          </div>

          <!-- Toolbar bas-droite — sibling du SVG pour ne pas être clippée
               CTA Aléatoire (gauche) + Paramètres (droite), ancrée au coin bas-droit -->
          <div class="cover-toolbar">
            <button type="button"
                    class="cover-pill cover-pill--icon cover-pill--reveal editor-randomize"
                    data-action="click->cover-editor#randomize"
                    aria-label="Générer une couverture aléatoire">
              <svg xmlns="http://www.w3.org/2000/svg"
                   class="cover-pill__icon"
                   viewBox="0 0 24 24"
                   fill="none"
                   stroke="currentColor"
                   stroke-width="1.8"
                   stroke-linecap="round"
                   stroke-linejoin="round"
                   aria-hidden="true">
                <rect width="12" height="12" x="2" y="10" rx="2" ry="2"/>
                <path d="m17.92 14 3.5-3.5a2.24 2.24 0 0 0 0-3l-5-4.92a2.24 2.24 0 0 0-3 0L10 6"/>
                <path d="M6 18h.01"/>
                <path d="M10 14h.01"/>
                <path d="M15 6h.01"/>
                <path d="M18 9h.01"/>
              </svg>
            </button>

            <!-- Carte de contrôles : header pill + body popover qui s'ouvre vers le haut -->
            <div class="cover-controls" data-cover-editor-target="controlsCard">
              <button type="button"
                      class="cover-controls__head cover-pill cover-pill--reveal"
                      data-action="click->cover-editor#toggleControls"
                      aria-expanded="true"
                      aria-controls="cover-controls-body">
                <span class="cover-controls__title">Paramètres de la couverture</span>
                <svg xmlns="http://www.w3.org/2000/svg"
                     class="cover-controls__chev"
                     data-cover-editor-target="controlsToggleIcon"
                     viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
                  <polyline points="4 10 8 6 12 10"/>
                </svg>
              </button>

                <div class="cover-controls__body" id="cover-controls-body">
                  <div class="cc-stack">
                    <!-- SYMÉTRIE -->
                    <div class="cc-row">
                      <span class="cc-label">Symétrie</span>
                      <div class="cc-segmented" role="radiogroup" aria-label="Symétrie">
                        <button type="button"
                                class="cc-segmented__btn"
                                data-cover-editor-target="symmetryMode"
                                data-action="click->cover-editor#updateCurve"
                                data-value="x4"
                                role="radio">×4</button>
                        <button type="button"
                                class="cc-segmented__btn"
                                data-cover-editor-target="symmetryMode"
                                data-action="click->cover-editor#updateCurve"
                                data-value="x8"
                                role="radio">×8</button>
                        <button type="button"
                                class="cc-segmented__btn"
                                data-cover-editor-target="symmetryMode"
                                data-action="click->cover-editor#updateCurve"
                                data-value="x16"
                                role="radio">×16</button>
                      </div>
                    </div>

                    <!-- TEINTE -->
                    <div class="cc-row">
                      <div class="cc-label-row">
                        <span class="cc-label">Teinte</span>
                        <span class="cc-value tabular-nums" data-cover-editor-target="hueValue">280</span>
                      </div>
                      <input
                        type="range"
                        id="hue"
                        data-cover-editor-target="colorPicker"
                        data-action="input->cover-editor#updateColors input->cover-editor#updateTitle input->cover-editor#updateCurve input->cover-editor#updateValueDisplays"
                        min="0"
                        max="360"
                        value="280"
                        aria-label="Teinte"
                        class="cc-slider cc-slider--hue"
                      >
                    </div>

                    <!-- LISSAGE -->
                    <div class="cc-row">
                      <div class="cc-label-row">
                        <span class="cc-label">Lissage</span>
                        <span class="cc-value tabular-nums" data-cover-editor-target="smoothingValue">50</span>
                      </div>
                      <input
                        type="range"
                        data-cover-editor-target="smoothing"
                        data-action="input->cover-editor#updateCurve input->cover-editor#updateValueDisplays"
                        min="10"
                        max="100"
                        value="50"
                        aria-label="Lissage"
                        class="cc-slider"
                      >
                    </div>

                    <!-- Courbe + Grille — paire côte à côte -->
                    <div class="cc-pair">
                      <div class="cc-row cc-row--grid">
                        <div class="cc-label-row">
                          <span class="cc-label">Courbe</span>
                          <span class="cc-value tabular-nums" data-cover-editor-target="curveValue">50, 50</span>
                        </div>
                        <div class="cc-grid"
                             data-pattern-grid="1"
                             data-controller="tooltip"
                             data-tooltip-text-value="Forme du motif">
                          <div class="cc-grid__lines" data-cover-editor-target="grid" data-pattern-grid="1"></div>
                          <div class="cc-grid__handle"
                               data-cover-editor-target="anchor1"
                               data-action="mousedown->cover-editor#startDrag touchstart->cover-editor#startDrag mousemove->cover-editor#drag touchmove->cover-editor#drag mouseup->cover-editor#stopDrag touchend->cover-editor#stopDrag"
                               aria-label="Point de contrôle de la courbe"
                               role="slider"></div>
                        </div>
                      </div>

                      <div class="cc-row cc-row--grid">
                        <div class="cc-label-row">
                          <span class="cc-label">Grille</span>
                          <span class="cc-value tabular-nums" data-cover-editor-target="gridValue">2 × 2</span>
                        </div>
                        <div class="cc-grid"
                             data-pattern-grid="2"
                             data-controller="tooltip"
                             data-tooltip-text-value="Répétition du motif">
                          <div class="cc-grid__lines cc-grid__lines--quad" data-cover-editor-target="grid" data-pattern-grid="2"></div>
                          <div class="cc-grid__handle"
                               data-cover-editor-target="anchor2"
                               data-action="mousedown->cover-editor#startDrag touchstart->cover-editor#startDrag mousemove->cover-editor#drag touchmove->cover-editor#drag mouseup->cover-editor#stopDrag touchend->cover-editor#stopDrag"
                               aria-label="Densité de la grille"
                               role="slider"></div>
                        </div>
                      </div>

                    </div>
                  </div>

                  <input type="range" data-cover-editor-target="firstSliderControl" data-action="input->cover-editor#updateCurve" class="hidden">
                  <input type="range" data-cover-editor-target="secondSliderControl" data-action="input->cover-editor#updateCurve" class="hidden">
                  <input data-cover-editor-target="rows" data-action="input->cover-editor#updateCurve" class="hidden">
                  <input data-cover-editor-target="columns" data-action="input->cover-editor#updateCurve" class="hidden">
                  <%= form.hidden_field :pattern_settings, data: { "cover-editor-target": "patternSettings" } %>
                  <%= form.hidden_field :cover, data: { "cover-editor-target": "cover" } %>
                </div>
              </div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Colonne de droite : contenu -->
      <main class="form-right-panel">
        <div class="editor-body">
          <!-- Titre du futur — input minimaliste, gros caractères -->
          <div class="editor-title-field editor-stagger">
            <label for="post_title" class="sr-only">Titre du futur</label>
            <%= form.text_field :title,
                                id: "post_title",
                                class: "editor-title-input",
                                placeholder: "Ton futur titre…",
                                value: @post.title,
                                required: true,
                                data: { action: "input->cover-editor#updateTitle", "cover-editor-target": "titleInput" } %>
            <p class="editor-error mt-2 hidden" data-preview-target="titleError">Le titre est requis</p>
          </div>

          <!-- Code événement — optionnel, révélé par un switch -->
          <% event_code_str = @post.event_code&.code.to_s %>
          <% event_code_active = event_code_str.present? %>
          <div class="editor-meta-row editor-stagger flex w-full flex-col gap-3"
               data-controller="event-code-field">
            <div class="grid w-full grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-1">
              <span id="post-event-code-switch-label" class="editor-field__label font-mono min-w-0">Code événement</span>
              <button type="button"
                      class="cover-pill cover-pill--sm cover-pill--ghost editor-draft-pill <%= 'is-on' if event_code_active %>"
                      role="switch"
                      aria-checked="<%= event_code_active ? 'true' : 'false' %>"
                      aria-labelledby="post-event-code-switch-label"
                      aria-controls="post-event-code-panel"
                      data-event-code-field-target="switch"
                      data-action="click->event-code-field#toggle">
                <span class="cover-pill__dot" aria-hidden="true"></span>
                <span class="cover-pill__label">Renseigner un code</span>
              </button>
            </div>
            <div id="post-event-code-panel"
                 class="w-full<%= 'hidden' unless event_code_active %>"
                 data-event-code-field-target="panel">
              <label class="editor-field">
                <span class="editor-field__label font-mono sr-only">Code événement</span>
                <%= form.text_field :event_code,
                                    value: event_code_str.presence,
                                    class: "editor-input editor-input--compact",
                                    placeholder: "Code de l’événement",
                                    data: { event_code_field_target: "input" } %>
              </label>
            </div>
          </div>

          <!-- Corps du texte -->
          <div class="editor-body-field editor-stagger">
            <%= form.text_area :body,
                               id: "post_body",
                               class: "editor-textarea",
                               rows: 12,
                               placeholder: "Écris ton futur ici…" %>
          </div>

          <!-- Chapitres -->
          <section class="chapters editor-stagger" aria-labelledby="chapters-title">
            <header class="chapters__header">
              <div class="chapters__title-group">
                <h2 id="chapters-title" class="chapters__title font-mono">Chapitres</h2>
                <span class="chapters__count font-mono tabular-nums" data-chapter-target="count">00</span>
              </div>
              <p class="chapters__hint">Découpe ton récit en chapitres pour le rendre plus lisible.</p>
            </header>

            <div id="chapters" class="chapters__list" data-chapter-target="chapters">
              <%= form.fields_for :chapters do |chapter_form| %>
                <article class="chapter-card" data-chapter-target="chapter">
                  <header class="chapter-card__header">
                    <div class="chapter-card__index font-mono">
                      <span aria-hidden="true">Chapitre</span>
                      <span class="tabular-nums" data-chapter-target="chapterNumber">1</span>
                    </div>
                    <button type="button"
                            class="chapter-card__delete"
                            data-action="click->chapter#removeChapter"
                            aria-label="Supprimer ce chapitre">
                      <svg viewBox="0 0 16 16" class="size-3.5" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path d="M3 3l10 10M13 3L3 13"/>
                      </svg>
                    </button>
                  </header>
                  <div class="hidden" data-chapter-target="chapterIndex">
                    <%= chapter_form.options[:child_index] %>
                  </div>

                  <%= chapter_form.text_field :title,
                                              class: "chapter-card__title-input",
                                              placeholder: "Titre du chapitre" %>
                  <%= chapter_form.text_area :body,
                                             class: "chapter-card__body-input",
                                             rows: 6,
                                             placeholder: "Texte du chapitre…" %>

                  <%= chapter_form.hidden_field :position %>
                  <%= chapter_form.hidden_field :_destroy %>
                </article>
              <% end %>
            </div>

            <button type="button"
                    class="chapters__add"
                    data-action="click->chapter#addChapter">
              <span class="chapters__add-icon" aria-hidden="true">+</span>
              <span>Ajouter un chapitre</span>
            </button>
          </section>
        </div>

        <!-- Barre d'action sticky bas (vibe bottomnavbar) -->
        <footer class="editor-actionbar">
          <div class="editor-actionbar__inner">
            <div class="editor-actionbar__meta font-mono">
              <span class="editor-actionbar__type">
                <%= @post.new_record? ? "Le futur de #{current_user.username}" : "Futur de #{current_user.username}" %>
              </span>
              <% if !@post.new_record? %>
                <span aria-hidden="true">·</span>
                <span class="tabular-nums">Créé le <%= @post.created_at.strftime("%d.%m.%Y") %></span>
              <% end %>
            </div>

            <div class="editor-actionbar__actions">
              <% draft_active = @post.draft %>
              <%# Brouillon : pill toggleable. État "on" = filled (charcoal), "off" = ghost. %>
              <button type="button"
                      class="cover-pill cover-pill--sm cover-pill--ghost editor-draft-pill <%= 'is-on' if draft_active %>"
                      role="switch"
                      aria-checked="<%= draft_active ? 'true' : 'false' %>"
                      data-action="click->cover-editor#toggleDraft">
                <span class="cover-pill__dot" aria-hidden="true"></span>
                <span class="cover-pill__label">Brouillon</span>
              </button>
              <%= form.hidden_field :draft, value: @post.draft, data: { "cover-editor-target": "draft" } %>

              <% submit_label =
                   if draft_active
                     "Enregistrer"
                   elsif @post.new_record?
                     "Publier"
                   else
                     "Éditer"
                   end %>
              <%= form.submit submit_label,
                              class: "cover-pill cover-pill--sm cover-pill--filled",
                              data: { "cover-editor-target": "submitButton", action: "click->preview#validateForm" } %>
            </div>
          </div>
        </footer>
      </main>
    </div>
  <% end %>
</div>

<script>
  // Empêcher la propagation du scroll depuis les textarea vers la page
  document.addEventListener('wheel', function(e) {
    const textarea = e.target.closest('textarea');
    if (textarea) {
      const { scrollTop, scrollHeight, clientHeight } = textarea;
      const isAtTop = scrollTop === 0;
      const isAtBottom = scrollTop + clientHeight >= scrollHeight - 1;

      if ((e.deltaY < 0 && isAtTop) || (e.deltaY > 0 && isAtBottom)) {
        e.preventDefault();
      } else {
        e.stopPropagation();
      }
    }
  }, { passive: false });
</script>

<% content_for :title, "SP 2050 - Mot de passe oublié" %>
<% content_for :description, "Réinitialise ton mot de passe SP 2050. Retrouve l'accès à ton compte en quelques étapes simples." %>
<% content_for :meta_robots, "noindex, nofollow" %>
<% content_for :navbar_transparent, true %>

<div class="auth-page" data-controller="auth-background">
  <!-- Animated SVG pattern background -->
  <div class="auth-bg" data-auth-background-target="svg"></div>
  <div class="auth-overlay"></div>

  <!-- Form -->
  <div class="auth-form-container">
    <div class="auth-form">
      <h2 class="auth-form__title">Mot de passe oublié</h2>
      <p class="auth-form__subtitle">On t'envoie un lien par email</p>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
        <%= f.error_notification %>

        <div class="auth-form__fields">
          <%= f.input :email,
                      label: "Adresse e-mail",
                      required: true,
                      autofocus: true,
                      input_html: { autocomplete: "email", class: 'auth-input', placeholder: "ton@email.com" },
                      label_html: { class: "auth-label" } %>
        </div>

        <div class="auth-form__actions">
          <%= f.button :submit, "Envoyer les instructions", class: "auth-btn-primary", data: { form_type: "other" } %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

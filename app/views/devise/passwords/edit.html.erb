<% content_for :title, "SP 2050 - Nouveau mot de passe" %>
<% content_for :description, "Choisis un nouveau mot de passe pour ton compte SP 2050." %>
<% content_for :meta_robots, "noindex, nofollow" %>
<% content_for :navbar_transparent, true %>

<div class="auth-page" data-controller="auth-background">
  <!-- Animated SVG pattern background -->
  <div class="auth-bg" data-auth-background-target="svg"></div>
  <div class="auth-overlay"></div>

  <!-- Form -->
  <div class="auth-form-container">
    <div class="auth-form">
      <h2 class="auth-form__title">Nouveau mot de passe</h2>
      <p class="auth-form__subtitle">Choisis ton nouveau sesame</p>

      <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.error_notification %>
        <%= f.input :reset_password_token, as: :hidden %>
        <%= f.full_error :reset_password_token, class: "text-red-400 text-sm mt-2 text-center" %>

        <div class="auth-form__fields">
          <%= f.input :password,
                      label: "Nouveau mot de passe",
                      required: true,
                      autofocus: true,
                      hint: ("#{@minimum_password_length} caracteres minimum" if @minimum_password_length),
                      hint_html: { class: "text-xs text-white/40 mt-1" },
                      input_html: { autocomplete: "new-password", class: 'auth-input', placeholder: "••••••••" },
                      label_html: { class: "auth-label" } %>

          <%= f.input :password_confirmation,
                      label: "Confirmer le mot de passe",
                      required: true,
                      input_html: { autocomplete: "new-password", class: 'auth-input', placeholder: "••••••••" },
                      label_html: { class: "auth-label" } %>
        </div>

        <div class="auth-form__actions">
          <%= f.button :submit, "Mettre à jour", class: "auth-btn-primary", data: { form_type: "other" } %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>

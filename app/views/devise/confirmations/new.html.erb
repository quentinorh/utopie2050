<% content_for :title, "SP 2050 - Confirmation d'inscription" %>
<% content_for :description, "Confirme ton compte SP 2050 pour accéder à toutes les fonctionnalités de la plateforme." %>
<% content_for :meta_robots, "noindex, nofollow" %>
<% content_for :navbar_transparent, true %>

<div class="auth-page" data-controller="auth-background">
  <!-- Animated SVG pattern background -->
  <div class="auth-bg" data-auth-background-target="svg"></div>
  <div class="auth-overlay"></div>

  <!-- Form -->
  <div class="auth-form-container">
    <div class="auth-form">
      <h2 class="auth-form__title">Confirmer mon compte</h2>
      <p class="auth-form__subtitle">Renvoyer le lien de confirmation</p>

      <%= simple_form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post }) do |f| %>
        <%= f.error_notification %>
        <%= f.full_error :confirmation_token, class: "text-red-400 text-sm mt-2 text-center" %>

        <div class="auth-form__fields">
          <%= f.input :email,
                      label: "Adresse e-mail",
                      required: true,
                      autofocus: true,
                      value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                      input_html: { autocomplete: "email", class: 'auth-input', placeholder: "ton@email.com" },
                      label_html: { class: "auth-label" } %>
        </div>

        <div class="auth-form__actions">
          <%= f.button :submit, "Renvoyer le lien", class: "auth-btn-primary", data: { form_type: "other" } %>
        </div>
      <% end %>

      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
